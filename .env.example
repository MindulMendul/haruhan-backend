# Supabase/PostgreSQL 연결 문자열 (미설정 시 DB 관련 기능은 비활성화됨)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Ollama 엔진 base URL
OLLAMA_BASE_URL=http://localhost:11434

# 콤마로 구분된 허용 origin 목록. 비우면 모든 cross-origin 요청이 차단됨.
CORS_ORIGINS=https://example.com,https://app.example.com

# /api/chat 인증용 키. 미설정 시 인증이 비활성화되므로 운영 환경에서는 반드시 설정할 것.
API_KEY=

# /api/chat 레이트 리밋 (limits 라이브러리 문법: "10/minute", "100/hour" 등)
CHAT_RATE_LIMIT=10/minute

# prompt 최대 길이 (문자 수)
MAX_PROMPT_LENGTH=4000

# 요청 바디 최대 크기 (바이트). 기본 1MB.
MAX_BODY_SIZE_BYTES=1048576

# 설정하면 레이트 리밋이 Redis를 공유 스토리지로 사용한다 (다중 워커/인스턴스 배포용).
# 비워두면 인메모리 스토리지 사용 (단일 프로세스 한정으로만 정확함).
REDIS_URL=

LOG_LEVEL=INFO
ENVIRONMENT=development
