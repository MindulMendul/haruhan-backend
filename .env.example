# caddy(리버스 프록시)가 HTTPS 인증서를 발급받을 도메인.
# docker-compose.yml의 caddy 서비스에서만 쓰임 (앱 자체는 이 값을 안 읽음).
DOMAIN=api.example.com

# Supabase/PostgreSQL 연결 문자열 (미설정 시 DB 관련 기능은 비활성화됨)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Ollama 엔진 base URL
OLLAMA_BASE_URL=http://localhost:11434

# 콤마로 구분된 허용 origin 목록. 비우면 모든 cross-origin 요청이 차단됨.
CORS_ORIGINS=https://example.com,https://app.example.com

# /api/chat 인증용 키. 미설정 시 인증이 비활성화되므로 운영 환경에서는 반드시 설정할 것.
API_KEY=

# LLM 호출 엔드포인트(chat/study/quiz/interview) 공통 레이트 리밋
# (limits 라이브러리 문법: "10/minute", "100/hour" 등)
CHAT_RATE_LIMIT=10/minute

# 로그인/회원가입/프로필수정처럼 브루트포스 대상이 될 수 있는 엔드포인트용 제한
AUTH_RATE_LIMIT=5/minute

# prompt/메시지 최대 길이 (문자 수)
MAX_PROMPT_LENGTH=4000

# 퀴즈 생성 소스 텍스트 최대 길이 (문자 수)
MAX_QUIZ_SOURCE_LENGTH=20000
DEFAULT_QUIZ_QUESTION_COUNT=5
MAX_QUIZ_QUESTION_COUNT=20

# 면접 연습 세션 하나당 최대 질문 수
MAX_INTERVIEW_QUESTIONS=5

# 면접 복기 content 최대 길이 (문자 수)
MAX_REVIEW_CONTENT_LENGTH=10000

# 학습챗 RAG 검색용 임베딩 모델. Ollama에 별도로 pull 되어 있어야 한다 (예: ollama pull nomic-embed-text).
EMBEDDING_MODEL=nomic-embed-text
# 학습챗 답변 생성 시 참고자료로 첨부할 최대 청크 개수
RAG_TOP_K=3

# 요청 바디 최대 크기 (바이트). 기본 1MB.
MAX_BODY_SIZE_BYTES=1048576

# 설정하면 레이트 리밋이 Redis를 공유 스토리지로 사용한다 (다중 워커/인스턴스 배포용).
# 비워두면 인메모리 스토리지 사용 (단일 프로세스 한정으로만 정확함).
REDIS_URL=

# JWT 서명 키. 필수값이라 설정하지 않으면 앱이 시작되지 않는다.
# 생성: openssl rand -hex 32  (32바이트 미만이면 PyJWT가 InsecureKeyLengthWarning을 띄운다)
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14

LOG_LEVEL=INFO
# production으로 설정하면 /docs, /redoc, /openapi.json이 비활성화된다.
ENVIRONMENT=development
